{
  "name": "to-buy",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:client": "bun ./node_modules/vite/bin/vite.js",
    "dev:server": "bun --watch src/server/index.ts",
    "build": "bun run codegen && bun run build:client",
    "build:client": "bun ./node_modules/vite/bin/vite.js build",
    "check": "./node_modules/.bin/tsc --noEmit",
    "codegen": "bun ./node_modules/@pandacss/dev/bin.js codegen && bun ./node_modules/@pandacss/dev/bin.js cssgen --outfile src/styled-system/styles.css"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@pandacss/dev": "^1.10.0",
    "@pandacss/preset-panda": "^1.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "bun-types": "^1.3.13",
    "lightningcss-darwin-arm64": "^1.31.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
